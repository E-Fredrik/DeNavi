// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
}

datasource db {
  provider = "postgresql"
}

model Organizer {
  id           String   @id @default(uuid())
  name         String
  whatsapp     String?
  // Access code remains available as an optional fallback login method.
  accessCode   String?  @unique // Format: NAVI-XXXX-XXXX
  // Clerk user ID from Clerk session/user object (e.g. user_xxx)
  clerkUserId  String?  @unique
  email        String?  @unique
  authProvider AuthProvider @default(ACCESS_CODE)
  lastSignInAt DateTime?
  signInCount  Int      @default(0)
  tokenBalance Int      @default(0)
  events       Event[]
  signInEvents SignInEvent[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Event {
  id          String   @id @default(uuid())
  organizerId String
  organizer   Organizer @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  name        String
  date        DateTime
  tokenCost   Int
  guests      Guest[]
  createdAt   DateTime @default(now())
}

model Guest {
  id           String   @id @default(uuid())
  eventId      String
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name         String
  qrTicket     String   @unique
  hasCheckedIn Boolean  @default(false)
  isPlusOne    Boolean  @default(false)
  checkInTime  DateTime?
}

model SignInEvent {
  id          String         @id @default(uuid())
  organizerId String
  organizer   Organizer      @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  provider    SignInProvider
  clerkUserId String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime       @default(now())

  @@index([organizerId, createdAt])
  @@index([clerkUserId, createdAt])
}

enum AuthProvider {
  ACCESS_CODE
  CLERK
  BOTH
}

enum SignInProvider {
  ACCESS_CODE
  CLERK
}

